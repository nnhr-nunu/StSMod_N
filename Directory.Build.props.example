<Project>
    <PropertyGroup>
        <!-- MegaDot / Godot 4.5.1 mono executable used for export-pack when publishing -->
        <!-- Megadot current version is 4.5.1, and the game won't load your .pck if the Godot version used is newer. -->
        <!-- macOS (default install via https://megadot.megacrit.com/install.sh): -->
        <GodotPath>$(HOME)/Applications/MegaDot.app/Contents/MacOS/Godot</GodotPath>
        <!-- Windows example: -->
        <!-- <GodotPath>C:/megadot/MegaDot_v4.5.1-stable_mono_win64.exe</GodotPath> -->

        <!-- If sts2 is not found automatically, uncomment and set manually -->
        <!-- <Sts2Path>$(HOME)/Library/Application Support/Steam/steamapps/common/Slay the Spire 2</Sts2Path> -->
    </PropertyGroup>
</Project>
